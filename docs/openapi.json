{
  "components": {
    "parameters": {
      "chatID": {
        "in": "path",
        "name": "chatID",
        "required": true,
        "schema": {
          "format": "uuid",
          "type": "string"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorEnvelope"
            }
          }
        },
        "description": "Geçersiz istek"
      },
      "NotFound": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorEnvelope"
            }
          }
        },
        "description": "Kaynak bulunamadı"
      },
      "ProviderError": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorEnvelope"
            }
          }
        },
        "description": "LLM provider hatası"
      },
      "ProviderTimeout": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorEnvelope"
            }
          }
        },
        "description": "LLM provider zaman aşımı"
      },
      "QuotaExceeded": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorEnvelope"
            }
          }
        },
        "description": "Token kotası aşıldı"
      },
      "Unauthorized": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorEnvelope"
            }
          }
        },
        "description": "Kimlik doğrulama gerekli"
      }
    },
    "schemas": {
      "AssistantResponse": {
        "properties": {
          "assistantMessage": {
            "$ref": "#/components/schemas/ChatMessage"
          },
          "usage": {
            "additionalProperties": true,
            "type": "object"
          }
        },
        "required": [
          "assistantMessage"
        ],
        "type": "object"
      },
      "AuthenticatedUser": {
        "properties": {
          "Email": {
            "format": "email",
            "type": "string"
          },
          "Role": {
            "type": "string"
          },
          "UserID": {
            "format": "uuid",
            "type": "string"
          }
        },
        "required": [
          "UserID",
          "Email",
          "Role"
        ],
        "type": "object"
      },
      "ChatDetail": {
        "properties": {
          "id": {
            "format": "uuid",
            "type": "string"
          },
          "messages": {
            "items": {
              "$ref": "#/components/schemas/ChatMessage"
            },
            "type": "array"
          },
          "model": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "provider",
          "model",
          "messages"
        ],
        "type": "object"
      },
      "ChatListItem": {
        "properties": {
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "type": "string"
          },
          "lastMessagePreview": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "provider",
          "model",
          "createdAt",
          "updatedAt"
        ],
        "type": "object"
      },
      "ChatMessage": {
        "properties": {
          "content": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "role": {
            "enum": [
              "user",
              "assistant",
              "system"
            ],
            "type": "string"
          }
        },
        "required": [
          "role",
          "content"
        ],
        "type": "object"
      },
      "CreateSessionRequest": {
        "properties": {
          "model": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "CreateSessionResponse": {
        "properties": {
          "id": {
            "format": "uuid",
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "provider",
          "model"
        ],
        "type": "object"
      },
      "ErrorBody": {
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "type": "object"
      },
      "ErrorEnvelope": {
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorBody"
          }
        },
        "required": [
          "error"
        ],
        "type": "object"
      },
      "ListProvidersResponse": {
        "properties": {
          "default": {
            "type": "string"
          },
          "providers": {
            "items": {
              "$ref": "#/components/schemas/ProviderInfo"
            },
            "type": "array"
          }
        },
        "required": [
          "default",
          "providers"
        ],
        "type": "object"
      },
      "PostMessageRequest": {
        "properties": {
          "content": {
            "type": "string"
          },
          "messages": {
            "items": {
              "$ref": "#/components/schemas/ChatMessage"
            },
            "type": "array"
          },
          "model": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "ProviderInfo": {
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "model": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "model",
          "enabled"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "bearerFormat": "JWT",
        "description": "Supabase access token",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "LLM sohbet backend servisi.\nSupabase tabanlı kimlik doğrulama, çoklu LLM provider desteği,\ntoken kota yönetimi ve etkileşim audit loglama içerir.\n",
    "title": "THY Case Study Backend API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/chats": {
      "get": {
        "operationId": "listSessions",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ChatListItem"
                  },
                  "type": "array"
                }
              }
            },
            "description": "Sohbet listesi"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "Sohbet listesi",
        "tags": [
          "chats"
        ]
      },
      "post": {
        "operationId": "createSession",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSessionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateSessionResponse"
                }
              }
            },
            "description": "Oturum oluşturuldu"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "Yeni sohbet oturumu oluştur",
        "tags": [
          "chats"
        ]
      }
    },
    "/chats/search": {
      "get": {
        "operationId": "searchChats",
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "SearchChats",
        "tags": [
          "misc"
        ]
      }
    },
    "/chats/{chatID}": {
      "delete": {
        "operationId": "deleteSession",
        "parameters": [
          {
            "$ref": "#/components/parameters/chatID"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "DeleteSession",
        "tags": [
          "misc"
        ]
      },
      "get": {
        "operationId": "getChat",
        "parameters": [
          {
            "$ref": "#/components/parameters/chatID"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatDetail"
                }
              }
            },
            "description": "Sohbet detayı"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "summary": "Sohbet detayı",
        "tags": [
          "chats"
        ]
      }
    },
    "/chats/{chatID}/messages": {
      "get": {
        "operationId": "listMessages",
        "parameters": [
          {
            "$ref": "#/components/parameters/chatID"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "ListMessages",
        "tags": [
          "misc"
        ]
      },
      "post": {
        "operationId": "postMessage",
        "parameters": [
          {
            "$ref": "#/components/parameters/chatID"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PostMessageRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssistantResponse"
                }
              }
            },
            "description": "Asistan yanıtı"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/QuotaExceeded"
          },
          "502": {
            "$ref": "#/components/responses/ProviderError"
          },
          "504": {
            "$ref": "#/components/responses/ProviderTimeout"
          }
        },
        "summary": "Mesaj gönder (non-stream)",
        "tags": [
          "messages"
        ]
      }
    },
    "/chats/{chatID}/messages/{messageID}": {
      "delete": {
        "operationId": "deleteMessage",
        "parameters": [
          {
            "$ref": "#/components/parameters/chatID"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "DeleteMessage",
        "tags": [
          "misc"
        ]
      }
    },
    "/chats/{chatID}/stream": {
      "post": {
        "operationId": "streamMessage",
        "parameters": [
          {
            "$ref": "#/components/parameters/chatID"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PostMessageRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "description": "Server-Sent Events stream"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/QuotaExceeded"
          },
          "502": {
            "$ref": "#/components/responses/ProviderError"
          },
          "504": {
            "$ref": "#/components/responses/ProviderTimeout"
          }
        },
        "summary": "Mesaj gönder (SSE stream)",
        "tags": [
          "messages"
        ]
      }
    },
    "/health": {
      "get": {
        "operationId": "health",
        "responses": {
          "200": {
            "content": {
              "text/plain": {
                "schema": {
                  "example": "OK",
                  "type": "string"
                }
              }
            },
            "description": "Servis aktif"
          }
        },
        "security": [],
        "summary": "Health check",
        "tags": [
          "health"
        ]
      }
    },
    "/me": {
      "get": {
        "operationId": "getMe",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticatedUser"
                }
              }
            },
            "description": "Kimlik doğrulanmış kullanıcı bilgisi"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "Mevcut kullanıcı bilgisi",
        "tags": [
          "auth"
        ]
      }
    },
    "/me/usage": {
      "get": {
        "operationId": "meUsage",
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "MeUsage",
        "tags": [
          "misc"
        ]
      }
    },
    "/providers": {
      "get": {
        "operationId": "listProviders",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListProvidersResponse"
                }
              }
            },
            "description": "Provider listesi"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "Aktif LLM provider listesi",
        "tags": [
          "providers"
        ]
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "servers": [
    {
      "description": "Default API base path",
      "url": "/api"
    }
  ],
  "tags": [
    {
      "description": "Sistem sağlık kontrolü",
      "name": "health"
    },
    {
      "description": "Kimlik doğrulama",
      "name": "auth"
    },
    {
      "description": "LLM provider yönetimi",
      "name": "providers"
    },
    {
      "description": "Sohbet oturumları",
      "name": "chats"
    },
    {
      "description": "Mesaj gönderme ve stream",
      "name": "messages"
    }
  ]
}
