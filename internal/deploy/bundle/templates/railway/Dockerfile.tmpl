# Build from repository root:
#   docker build -f Dockerfile .
# Module: {{.Module}}

FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/api {{.MainPackage}}

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
WORKDIR /app
COPY --from=build /out/api ./api
ENV PORT={{.Port}}
EXPOSE {{.Port}}
USER nobody
CMD ["./api"]
