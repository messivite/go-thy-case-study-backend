# cmd/api ve cmd/server .env dosyasını bulur (cwd → üst dizinler) ve godotenv Overload ile yükler (.env, shell export üzerine yazar).
PORT=8081
SUPABASE_URL=https://tiflvzkfadiqdpovlmik.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_JWT_VALIDATION_MODE=auto
SUPABASE_ROLE_CLAIM_KEY=role
# Chat + kota: supabase (varsayılan) — uzak Postgres; memory — sadece RAM (süreç kapanınca silinir, kota stub)
CHAT_PERSISTENCE=supabase
OPENAI_API_KEY=
GEMINI_API_KEY=
# GET /api/chats ve GET /api/chats/{id}/messages yanıt önbelleği (kapalı: CACHE_ENABLED boş/false). Açmak: thy-case-llm cache config
# CACHE_ENABLED=true
# CACHE_BACKEND=memory
# CACHE_TTL_CHAT_LIST_SEC=20
# CACHE_TTL_CHAT_MESSAGES_SEC=15
# Redis için CACHE_BACKEND=redis ve örnek:
# REDIS_ADDR=127.0.0.1:6379
# REDIS_DB=0
# REDIS_PASSWORD=
# Yapılandırılmış logları JSON Lines olarak dosyaya da yaz (Loki/Vector/Datadog agent ile tail edilebilir). Boş bırakınca sadece stdout dosyasına yazılır.
# OBSERVABILITY_LOG_FILE=./logs/app.jsonl
# OpenTelemetry trace → OTLP HTTP (Collector / Grafana / Jaeger). Boş bırakınca tracer yüklenmez.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=thy-case-study-api
# Swagger UI public path (auth gerektirmez)./docs-a7b3c9e2f1d4
# SWAGGER_PUBLIC_PATH=/docs-a7b3c9e2f1d4
